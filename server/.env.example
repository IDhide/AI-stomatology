# ════════════════════════════════════════════════════════════════════
#  Серверный backend — переменные окружения
#  Скопируйте в server/.env и заполните. Без ключей всё работает на mock.
# ════════════════════════════════════════════════════════════════════

# ── Выбор провайдеров ───────────────────────────────────────────────
LLM_PROVIDER=grok            # grok | mock
STT_PROVIDER=elevenlabs      # elevenlabs | mock
TTS_PROVIDER=elevenlabs      # elevenlabs | mock

# ── Grok (xAI) ──────────────────────────────────────────────────────
XAI_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=400

# ── ElevenLabs (STT Scribe + TTS Flash) ─────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=          # id женского русского голоса
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_OUTPUT_FORMAT=pcm_16000

# ── DIKIDI (только чтение записей; без ключей — демо-данные) ────────
DIKIDI_API_KEY=
DIKIDI_COMPANY_ID=
DIKIDI_BASE_URL=https://api.dikidi.net

# ── Supabase (память + лица) ────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Логика диалога ──────────────────────────────────────────────────
SILENCE_END_SECONDS=10
FACE_MATCH_THRESHOLD=0.42
REGREET_MINUTES=45
PROMPTS_PATH=config/prompts.yaml
