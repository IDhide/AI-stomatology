# ════════════════════════════════════════════════════════════
#  Smile.AI — переменные окружения
#  Скопируйте в .env и заполните своими значениями
# ════════════════════════════════════════════════════════════

# ── DIKIDI API ──────────────────────────────────────────────
DIKIDI_TOKEN=your_dikidi_token_here
DIKIDI_API_KEY=your_dikidi_api_key_here
DIKIDI_COMPANY_ID=your_company_id_here

# ── Ollama (LLM) ────────────────────────────────────────────
# По умолчанию: http://localhost:11434
# Для Docker: http://ollama:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=smile-ru

# ── Камера ──────────────────────────────────────────────────
# RTSP URL для IP-камеры (Xi C200 или другой)
# Оставьте пустым для USB-камеры (device_index из settings.yaml)
RTSP_URL=

# ── Приложение ──────────────────────────────────────────────
APP_ENV=development
# development | production
