# ════════════════════════════════════════════════════════════
#  Smile.AI — переменные окружения. Скопируйте в .env.
#  Для базового теста менять ничего не нужно (всё имеет дефолты).
# ════════════════════════════════════════════════════════════

# ── DIKIDI ──────────────────────────────────────────────────
# По умолчанию — тестовый сервер (в Docker это контейнер dikidi-sim).
# Для реального DIKIDI: укажите боевой адрес и токен.
DIKIDI_BASE_URL=http://127.0.0.1:8089
DIKIDI_TOKEN=demo-token

# ── Ollama (умный мозг) ─────────────────────────────────────
# Задаётся автоматически в docker-compose.smart.yml.
# Локально: OLLAMA_HOST=http://localhost:11434
OLLAMA_HOST=
OLLAMA_MODEL=qwen2.5:1.5b

# ── Голос Оливии (серверный TTS) ────────────────────────────
# fishaudio — живой голос Fish Speech / OpenAudio (лучшее качество, GPU,
#             отдельный контейнер, клонирование из assets/voice). make fish.
# xtts    — клонирование голоса XTTS v2 (лёгкий, быстрый, GPU/CPU).
# qwen3vc — клонирование голоса Qwen3-TTS-VC (тяжелее, нужен GPU).
# silero  — живой женский голос (по умолчанию, CPU).
# piper   — лёгкий запасной (ru_RU/irina).
TTS_ENGINE=silero
# Голос Silero: baya (тёплый/интимный) | xenia (чистый) | kseniya (мягкий)
SILERO_SPEAKER=baya
SILERO_SAMPLE_RATE=48000
# Темп речи для ASMR-подачи (через SSML). Пусто = обычный. slow | x-slow | 90%
SILERO_RATE=

# Живой голос (Fish Speech / OpenAudio) — только при TTS_ENGINE=fishaudio
# (запускается через make fish / make fish-cpu, см. docker-compose.fish.yml):
FISH_REF_AUDIO=/app/assets/voice/reference.mp3
FISH_REF_TEXT_FILE=/app/assets/voice/reference.txt
# Устройство выбирается автоматически: make fish = GPU, make fish-cpu = CPU.
# «Живость» голоса: больше = выразительнее/вольнее, меньше = ровнее
FISH_TEMPERATURE=0.7
FISH_TOP_P=0.7
FISH_REP_PENALTY=1.2

# Клонирование голоса XTTS v2 — только при TTS_ENGINE=xtts:
XTTS_REF_AUDIO=/app/assets/voice/reference.wav
XTTS_LANGUAGE=ru
XTTS_DEVICE=cuda
# COQUI_TOS_AGREED=1 — модель CPML (non-commercial), см. лицензию Coqui

# Клонирование голоса (Qwen3-TTS-VC) — только при TTS_ENGINE=qwen3vc:
QWEN_REF_AUDIO=/app/assets/voice/reference.wav
QWEN_REF_TEXT_FILE=/app/assets/voice/reference.txt
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_DEVICE=cuda:0
QWEN_LANGUAGE=Russian
QWEN_ATTN=sdpa

# ── Серверное распознавание речи (Firefox) ──────────────────
# tiny | base | small | medium
STT_MODEL=small

# ── Камера (детекция пациентов) ────────────────────────────
# RTSP URL через go2rtc или индекс USB-камеры (0, 1…).
# Если пусто — камера отключена, пациент нажимает экран сам.
CAMERA_SOURCE=
CAMERA_FPS=5
CAMERA_COOLDOWN=30
CAMERA_LOST_AFTER=5
