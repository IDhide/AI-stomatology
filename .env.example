# ════════════════════════════════════════════════════════════
#  Smile.AI — переменные окружения. Скопируйте в .env.
#  Для базового теста менять ничего не нужно (всё имеет дефолты).
# ════════════════════════════════════════════════════════════

# ── DIKIDI ──────────────────────────────────────────────────
# По умолчанию — тестовый сервер (в Docker это контейнер dikidi-sim).
# Для реального DIKIDI: укажите боевой адрес и токен.
DIKIDI_BASE_URL=http://127.0.0.1:8089
DIKIDI_TOKEN=demo-token

# ── Ollama (умный мозг) ─────────────────────────────────────
# Задаётся автоматически в docker-compose.smart.yml.
# Локально: OLLAMA_HOST=http://localhost:11434
OLLAMA_HOST=
OLLAMA_MODEL=qwen2.5:1.5b

# ── Голос Оливии (серверный TTS) ────────────────────────────
# qwen3vc — клонирование голоса из образца (нужен GPU). См. assets/voice/.
# silero  — живой женский голос (по умолчанию, нужен torch, работает на CPU).
# piper   — лёгкий запасной (ru_RU/irina).
TTS_ENGINE=silero
# Голос Silero: baya (тёплый) | xenia (чистый) | kseniya
SILERO_SPEAKER=baya
SILERO_SAMPLE_RATE=48000

# Клонирование голоса (Qwen3-TTS-VC) — только при TTS_ENGINE=qwen3vc:
QWEN_REF_AUDIO=/app/assets/voice/reference.wav
QWEN_REF_TEXT_FILE=/app/assets/voice/reference.txt
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_DEVICE=cuda:0
QWEN_LANGUAGE=Russian
QWEN_ATTN=sdpa

# ── Серверное распознавание речи (Firefox) ──────────────────
# tiny | base | small | medium
STT_MODEL=small

# ── Камера (детекция пациентов) ────────────────────────────
# RTSP URL через go2rtc или индекс USB-камеры (0, 1…).
# Если пусто — камера отключена, пациент нажимает экран сам.
CAMERA_SOURCE=
CAMERA_FPS=5
CAMERA_COOLDOWN=30
CAMERA_LOST_AFTER=5
